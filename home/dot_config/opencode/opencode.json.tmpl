{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@bybrawe/opencode-loop@0.5.1",
    "@khalilgharbaoui/opencode-claude-code-plugin@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "zhtw-mcp": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/.local/bin/zhtw-mcp"
      ],
      "enabled": true
    }
  },
  "instructions": [
    "{{ .chezmoi.homeDir }}/.config/opencode/instructions/zh-tw.md"
  ]
}
