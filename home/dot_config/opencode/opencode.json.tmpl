{
  "$schema": "https://opencode.ai/config.json",
  "shell": "fish",
  "plugin": {{ .ai.opencode.plugins | toPrettyJson }},
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "claude-code": {
      "options": {
        "proxyTools": [
          "Bash",
          "Edit",
          "Write",
          "WebFetch",
          "Task"
        ],
        "bridgeOpencodeMcp": true,
        "strictMcpConfig": false,
        "webSearch": "claude"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "zhtw-mcp": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/.local/bin/zhtw-mcp"
      ],
      "enabled": true
    }
  },
  "instructions": [
    "{{ .chezmoi.homeDir }}/.config/opencode/instructions/zh-tw.md"
  ]
}
