{{- /*
Noctalia widgets require connector names and absolute logical pixels.
Keep source portable by deriving those values from monitor roles and ratios.
*/ -}}
{{- $hyprland := and (eq .chezmoi.os "linux") (lookPath "hyprctl") (env "HYPRLAND_INSTANCE_SIGNATURE") (env "XDG_RUNTIME_DIR") -}}
{{- if $hyprland -}}
{{- $outputs := (output "hyprctl" "monitors" "-j" | jq "fromjson | map(select((.disabled != true) and ((.mirrorOf // \"none\") == \"none\"))) | sort_by(.x)" | first) -}}
{{- if ge (len $outputs) 3 -}}
{{- $center := index $outputs 1 -}}
{{- $right := index $outputs 2 -}}
{{- $centerName := index $center "name" -}}
{{- $centerTransform := printf "%v" (index $center "transform") -}}
{{- $centerRotated := or (eq $centerTransform "1") (eq $centerTransform "3") (eq $centerTransform "5") (eq $centerTransform "7") -}}
{{- $centerWidth := divf (index $center "width") (index $center "scale") -}}
{{- $centerHeight := divf (index $center "height") (index $center "scale") -}}
{{- if $centerRotated -}}
{{- $centerWidth = divf (index $center "height") (index $center "scale") -}}
{{- $centerHeight = divf (index $center "width") (index $center "scale") -}}
{{- end -}}
{{- $rightName := index $right "name" -}}
{{- $rightTransform := printf "%v" (index $right "transform") -}}
{{- $rightRotated := or (eq $rightTransform "1") (eq $rightTransform "3") (eq $rightTransform "5") (eq $rightTransform "7") -}}
{{- $rightWidth := divf (index $right "width") (index $right "scale") -}}
{{- $rightHeight := divf (index $right "height") (index $right "scale") -}}
{{- if $rightRotated -}}
{{- $rightWidth = divf (index $right "height") (index $right "scale") -}}
{{- $rightHeight = divf (index $right "width") (index $right "scale") -}}
{{- end -}}
{{- $lockClockHeightRatio := 0.1666666667 -}}
{{- $lockLoginHeightRatio := divf 70.0 1152.0 -}}
{{- $lockGroupGapRatio := divf 40.0 1152.0 -}}
{{- $lockGroupTopRatio := subf 0.5 (divf (addf $lockClockHeightRatio $lockLoginHeightRatio $lockGroupGapRatio) 2.0) -}}
{{- $lockClockYRatio := addf $lockGroupTopRatio (divf $lockClockHeightRatio 2.0) -}}
{{- $lockLoginYRatio := addf $lockGroupTopRatio $lockClockHeightRatio $lockGroupGapRatio (divf $lockLoginHeightRatio 2.0) -}}
# Generated by chezmoi from monitor roles and ratios.
# Edit this template, not the rendered TOML.

[desktop_widgets]
enabled = true
schema_version = 2
widget_order = ["desktop-audio-visualizer", "desktop-media-player"]

[desktop_widgets.grid]
cell_size = 16
major_interval = 4
visible = true

[desktop_widgets.widget.desktop-audio-visualizer]
type = "audio_visualizer"
output = "{{ $rightName }}"
cx = {{ printf "%.1f" (mulf 0.0833333333 $rightWidth) }}
cy = {{ printf "%.1f" (mulf 0.1740740741 $rightHeight) }}
box_width = {{ printf "%.1f" (mulf 0.1666666667 $rightWidth) }}
box_height = {{ printf "%.1f" (mulf 0.0740740741 $rightHeight) }}
rotation = 0.0
enabled = true

[desktop_widgets.widget.desktop-audio-visualizer.settings]
aspect_ratio = 3.5
background = false
background_color = "on_primary"
background_opacity = 0.34
bands = 32
color_1 = "on_primary"
color_2 = "on_secondary"
show_when_idle = false

[desktop_widgets.widget.desktop-media-player]
type = "media_player"
output = "{{ $rightName }}"
cx = {{ printf "%.1f" (mulf 0.0833333333 $rightWidth) }}
cy = {{ printf "%.1f" (mulf 0.0925925926 $rightHeight) }}
box_width = {{ printf "%.1f" (mulf 0.1666666667 $rightWidth) }}
box_height = {{ printf "%.1f" (mulf 0.1037037037 $rightHeight) }}
rotation = 0.0
enabled = true

[desktop_widgets.widget.desktop-media-player.settings]
background = false
background_opacity = 0.06
color = "on_surface_variant"
hide_when_no_media = true
layout = "horizontal"

[lockscreen_widgets]
enabled = true
schema_version = 2
widget_order = [{{ range $i, $monitor := $outputs }}{{ if $i }}, {{ end }}"lockscreen-login-box@{{ index $monitor "name" }}"{{ end }}, "lockscreen-clock-main", "lockscreen-sysmon-main"]

[lockscreen_widgets.grid]
cell_size = 16
major_interval = 4
visible = true

{{ range $monitor := $outputs }}
{{- $monitorName := index $monitor "name" -}}
{{- $monitorTransform := printf "%v" (index $monitor "transform") -}}
{{- $monitorRotated := or (eq $monitorTransform "1") (eq $monitorTransform "3") (eq $monitorTransform "5") (eq $monitorTransform "7") -}}
{{- $monitorWidth := divf (index $monitor "width") (index $monitor "scale") -}}
{{- $monitorHeight := divf (index $monitor "height") (index $monitor "scale") -}}
{{- if $monitorRotated -}}
{{- $monitorWidth = divf (index $monitor "height") (index $monitor "scale") -}}
{{- $monitorHeight = divf (index $monitor "width") (index $monitor "scale") -}}
{{- end -}}
[lockscreen_widgets.widget."lockscreen-login-box@{{ $monitorName }}"]
type = "login_box"
output = "{{ $monitorName }}"
cx = {{ printf "%.1f" (mulf 0.5 $monitorWidth) }}
cy = {{ if eq $monitorName $centerName }}{{ printf "%.1f" (mulf $lockLoginYRatio $monitorHeight) }}{{ else }}{{ printf "%.1f" (mulf 0.5 $monitorHeight) }}{{ end }}
box_width = 0.0
box_height = 0.0
rotation = 0.0
enabled = true

[lockscreen_widgets.widget."lockscreen-login-box@{{ $monitorName }}".settings]
background_color = "surface_variant"
background_opacity = 0.88
background_radius = 12.0
input_opacity = 1.0
input_radius = 6.0
show_login_button = true

{{ end -}}
[lockscreen_widgets.widget.lockscreen-clock-main]
type = "clock"
output = "{{ $centerName }}"
cx = {{ printf "%.1f" (mulf 0.5 $centerWidth) }}
cy = {{ printf "%.1f" (mulf $lockClockYRatio $centerHeight) }}
box_width = {{ printf "%.1f" (mulf 0.21875 $centerWidth) }}
box_height = {{ printf "%.1f" (mulf 0.1666666667 $centerHeight) }}
rotation = 0.0
enabled = true

[lockscreen_widgets.widget.lockscreen-clock-main.settings]
background = true
background_opacity = 0.0
clock_style = "digital"
color = "primary"
font_family = "JetBrains Mono NL Medium"
format = "{:%B %d, %Y}\\n{:%T}"

[lockscreen_widgets.widget.lockscreen-sysmon-main]
type = "sysmon"
output = "{{ $centerName }}"
cx = {{ printf "%.1f" (mulf 0.064453125 $centerWidth) }}
cy = {{ printf "%.1f" (mulf 0.9240451389 $centerHeight) }}
box_width = 0.0
box_height = 0.0
rotation = 0.0
enabled = true

[lockscreen_widgets.widget.lockscreen-sysmon-main.settings]
background_opacity = 0.0
font_family = "JetBrainsMono NF Medium"
stat2 = "ram_pct"
{{- end }}
{{- end }}
