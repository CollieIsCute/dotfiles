#!/bin/bash
set -euo pipefail

{{ if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos")) }}
export GREEN='\033[1;32m'
export YELLOW='\033[1;33m'
export NC='\033[0m'

echo -e "${GREEN}Configuring greetd + Noctalia Greeter...${NC}"

enable_sddm_fallback() {
  if [ -d /run/systemd/system ]; then
    sudo systemctl disable greetd.service >/dev/null 2>&1 || true
    sudo systemctl enable sddm.service >/dev/null 2>&1 || true
  fi
}

if ! command -v noctalia-greeter-session >/dev/null 2>&1; then
  echo -e "${YELLOW}Warning: noctalia-greeter-session not found; keeping SDDM enabled.${NC}"
  enable_sddm_fallback
  exit 0
fi

if ! getent passwd greeter >/dev/null 2>&1; then
  echo -e "${YELLOW}Warning: greeter user is missing; keeping SDDM enabled.${NC}"
  enable_sddm_fallback
  exit 0
fi

session_bin="$(command -v noctalia-greeter-session)"
setup_script="/usr/share/noctalia-greeter/setup_greeter_system.sh"

if [ ! -x "$setup_script" ]; then
  echo -e "${YELLOW}Warning: ${setup_script} not found; keeping SDDM enabled.${NC}"
  enable_sddm_fallback
  exit 0
fi

if ! sudo env GREETER_USER=greeter "$setup_script"; then
  echo -e "${YELLOW}Warning: Noctalia Greeter setup failed; keeping SDDM enabled.${NC}"
  enable_sddm_fallback
  exit 0
fi

sudo install -d -o root -g root -m 0755 /etc/greetd

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

cat > "${tmpdir}/config.toml" <<GREETD_CONFIG
[terminal]
vt = 1

[default_session]
command = "${session_bin}"
user = "greeter"
GREETD_CONFIG

sudo install -o root -g root -m 0644 "${tmpdir}/config.toml" /etc/greetd/config.toml

if [ -d /run/systemd/system ]; then
  # Do not stop/start display managers here; that can kill the current session.
  sudo systemctl disable sddm.service >/dev/null 2>&1 || true
  if sudo systemctl enable greetd.service; then
    echo -e "${GREEN}greetd is enabled. Reboot to switch from SDDM to Noctalia Greeter.${NC}"
  else
    echo -e "${YELLOW}Warning: failed to enable greetd; keeping SDDM enabled.${NC}"
    enable_sddm_fallback
  fi
else
  echo -e "${YELLOW}systemd is not running; skipping display-manager service switch.${NC}"
fi
{{ else }}
exit 0
{{ end }}
