#!/bin/bash
set -euo pipefail

{{ if and (eq .chezmoi.os "linux") (or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos")) }}
export GREEN='\033[1;32m'
export YELLOW='\033[1;33m'
export NC='\033[0m'

echo -e "${GREEN}Configuring greetd + ReGreet on Hyprland...${NC}"

for cmd in regreet start-hyprland dbus-run-session; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: $cmd is required but was not found." >&2
    exit 1
  fi
done

if ! getent passwd greeter >/dev/null 2>&1; then
  echo "Error: greeter user is missing. The greetd package should create it." >&2
  exit 1
fi

sudo install -d -o root -g root -m 0755 /etc/greetd
sudo install -d -o root -g root -m 0755 /etc/greetd/assets

wallpaper_source="${HOME}/.config/wallpapers/xp_wallpaper.jpg"
if [ -r "$wallpaper_source" ]; then
  sudo install -o root -g root -m 0644 "$wallpaper_source" /etc/greetd/assets/greeter.jpg
else
  echo -e "${YELLOW}Warning: ${wallpaper_source} not found; ReGreet background may be missing.${NC}"
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

cat > "${tmpdir}/config.toml" <<'GREETD_CONFIG'
[terminal]
vt = 1

[default_session]
command = "dbus-run-session start-hyprland -- --config /etc/greetd/hyprland.lua"
user = "greeter"
GREETD_CONFIG

cat > "${tmpdir}/hyprland.lua" <<'HYPRLAND_CONFIG'
-- chezmoi-managed ReGreet compositor config.
-- Keep this separate from the user's full Hyprland config.

hl.env("GTK_USE_PORTAL", "0")
hl.env("GDK_DEBUG", "no-portals")
hl.env("HYPRCURSOR_SIZE", "24")
hl.env("XCURSOR_THEME", "Catppuccin Mocha Green")
hl.env("XCURSOR_SIZE", "24")

hl.on("hyprland.start", function()
    hl.exec_cmd("regreet; hyprctl dispatch 'hl.dsp.exit()'")
end)

hl.config({
    ecosystem = {
        no_donation_nag = true,
    },
    misc = {
        disable_hyprland_logo = true,
        disable_splash_rendering = true,
        disable_hyprland_guiutils_check = true,
    },
})
HYPRLAND_CONFIG

cat > "${tmpdir}/regreet.toml" <<'REGREET_CONFIG'
skip_selection = false

[background]
path = "/etc/greetd/assets/greeter.jpg"
fit = "Cover"

[GTK]
application_prefer_dark_theme = true
cursor_theme_name = "Catppuccin Mocha Green"
font_name = "JetBrainsMono Nerd Font 12"
icon_theme_name = "Adwaita"
theme_name = "Adwaita"

[commands]
reboot = ["systemctl", "reboot"]
poweroff = ["systemctl", "poweroff"]

[appearance]
greeting_msg = "Welcome back"

[widget.clock]
format = "%a %H:%M"
resolution = "500ms"
REGREET_CONFIG

sudo install -o root -g root -m 0644 "${tmpdir}/config.toml" /etc/greetd/config.toml
sudo install -o root -g root -m 0644 "${tmpdir}/hyprland.lua" /etc/greetd/hyprland.lua
sudo install -o root -g root -m 0644 "${tmpdir}/regreet.toml" /etc/greetd/regreet.toml

if [ -d /run/systemd/system ]; then
  # Do not stop/start display managers here; that can kill the current session.
  sudo systemctl disable sddm.service >/dev/null 2>&1 || true
  sudo systemctl enable accounts-daemon.service >/dev/null 2>&1 || true
  sudo systemctl enable greetd.service
  echo -e "${GREEN}greetd is enabled. Reboot to switch from SDDM to ReGreet.${NC}"
else
  echo -e "${YELLOW}systemd is not running; skipping display-manager service switch.${NC}"
fi
{{ else }}
exit 0
{{ end }}
